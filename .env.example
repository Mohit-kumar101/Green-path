# Green-path / ShrinkPath — environment variables
#
# Local setup:
#   cp .env.example .env
#   set -a && source .env && set +a && ./mvnw spring-boot:run
#
# Never commit .env (use this file as the template).

# --- Server ---
# HTTP port (Spring: server.port)
PORT=8080

# --- MongoDB ---
# Primary variable used by application.properties. For Docker/Render, any ONE of the
# aliases below is enough (see MongoUriSources / docker-entrypoint.sh).
MONGODB_URI=mongodb://localhost:27017/greenpath

# Aliases (optional; only set if your host uses a different name)
# SPRING_DATA_MONGODB_URI=
# MONGO_URI=
# MONGO_URL=
# DATABASE_URL=

# Alternative for local dev without MONGODB_URI: uses application-local.properties
# SPRING_PROFILES_ACTIVE=local

# --- Public URL ---
# Base URL for short links and QR codes in API responses (no trailing slash)
PUBLIC_BASE_URL=http://localhost:8080

# --- Security / redirects ---
# Production: set true so only https:// targets can be shortened
URL_REQUIRE_HTTPS=false

# DNS-aware target validation (SSRF mitigation); disable only for local demos
REDIRECT_TARGET_SAFETY=true

# Salt for hashing client IPs in click analytics (change in production)
CLICK_FINGERPRINT_SALT=change-me-in-production

# --- App behavior ---
# Per-hit chaos redirect probability when chaosMode is enabled on a link (0–1)
CHAOS_PROBABILITY=0.12

# Per-API-key link create limit per rolling hour
RATE_LIMIT_CREATES_PER_HOUR=120

# --- Optional admin ---
# Enables POST /api/billing/demo-upgrade; leave empty to disable
BILLING_ADMIN_SECRET=

# --- Docker runtime (optional) ---
# Passed to java in docker-entrypoint.sh
# JAVA_OPTS=
